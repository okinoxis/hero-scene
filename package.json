{
  "name": "@okinoxis/hero-scene",
  "version": "0.4.2",
  "description": "Cinematic hero sections for Next.js — compound component API with image rotation, parallax, vignette overlays, blur masks, and dot patterns.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "size": "size-limit",
    "prepublishOnly": "npm run build && npm run publint && npm run size"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "10 KB"
    }
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next": "^16.1.6",
    "publint": "^0.3.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^11.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "hero",
    "parallax",
    "vignette",
    "nextjs",
    "react",
    "cinematic",
    "compound-component"
  ],
  "license": "MIT"
}
